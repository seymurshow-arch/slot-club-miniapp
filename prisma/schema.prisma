generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BalanceTransactionDirection {
  CREDIT
  DEBIT
}

enum BalanceTransactionSource {
  INITIAL_BALANCE
  TAP_REWARD
  TASK_REWARD
  DAILY_REWARD
  REFERRAL_REWARD
  SHOP_PURCHASE
  SHOP_REFUND
  ADMIN_ADJUSTMENT
  SYSTEM_ADJUSTMENT
  MIGRATION
}

enum ShopItemType {
  UPGRADE
  CONSUMABLE
  COSMETIC
}

enum ShopItemCategory {
  BOOSTS
  ENERGY
  TAP_SKINS
  AVATAR_FRAMES
  CHARMS
  SPECIAL
}

enum ShopItemEffect {
  TAP_POWER
  MAX_ENERGY
  ENERGY_RESTORE_AMOUNT
  FULL_ENERGY
  TAP_SKIN
  AVATAR_FRAME
  CHARM
  VIP_POINTS
  COINS
  SPECIAL_ITEM
}

enum ShopAcquisitionMethod {
  PURCHASE
  ACTION
  PURCHASE_OR_ACTION
  FREE
}

enum ShopPurchaseLimit {
  ONCE
  LIMITED
  UNLIMITED
}

enum ShopUnlockActionType {
  TELEGRAM_CHANNEL
  OPEN_LINK
  CUSTOM
  TAP_COUNT
  REFERRALS
  VIP_LEVEL
  MANUAL
}

enum ShopUnlockVerification {
  TELEGRAM_API
  GAME_LOGIC
  MANUAL_REVIEW
  AUTO_COMPLETE
  NO_VERIFICATION
}

enum ShopPurchaseStatus {
  COMPLETED
  REFUNDED
}

model User {
  id          String   @id @default(cuid())
  telegramId  BigInt   @unique
  username    String?
  firstName   String?
  lastName    String?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime @default(now())

  gameState           PlayerGameState?
  tapRateLimit        PlayerTapRateLimit?
  balanceTransactions BalanceTransaction[]
  targetedAuditLogs   AdminAuditLog[]      @relation("AuditTargetUser")

  shopItems     PlayerShopItem[]
  shopPurchases ShopPurchase[]

  @@index([createdAt])
  @@index([lastLoginAt])
}

model PlayerGameState {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance BigInt
  energy  BigInt

  maxEnergy        BigInt
  lastEnergyUpdate DateTime

  tapPower         BigInt
  energyCostPerTap BigInt

  totalTaps   BigInt @default(0)
  totalEarned BigInt @default(0)

  vipPoints BigInt @default(0)
  vipLevel  Int    @default(0)

  isBlocked            Boolean @default(false)
  isLeaderboardVisible Boolean @default(true)

  adminNote String?

  revision Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isBlocked])
  @@index([isLeaderboardVisible, totalEarned])
  @@index([isLeaderboardVisible, balance])
  @@index([updatedAt])
}

model PlayerTapRateLimit {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  windowStartedAt DateTime
  tapCount        Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([windowStartedAt])
}

model EconomySettings {
  id String @id @default("global")

  version Int @default(1)

  initialBalance   BigInt
  initialEnergy    BigInt
  initialMaxEnergy BigInt

  baseTapReward    BigInt
  energyCostPerTap BigInt

  energyRestoreAmount          BigInt
  energyRestoreIntervalSeconds Int
  maximumTapsPerSecond         Int
  maximumBalance               BigInt

  manualRewardPerActionLimit BigInt
  manualRewardDailyLimit     BigInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  history EconomySettingsHistory[]
}

model EconomySettingsHistory {
  id String @id @default(cuid())

  economySettingsId String
  economySettings   EconomySettings @relation(fields: [economySettingsId], references: [id], onDelete: Cascade)

  version  Int
  snapshot Json

  changedBy String
  reason    String?

  createdAt DateTime @default(now())

  @@unique([economySettingsId, version])
  @@index([createdAt])
}

model ShopItem {
  id String @id @default(cuid())

  key String @unique

  type              ShopItemType
  category          ShopItemCategory
  effect            ShopItemEffect
  acquisitionMethod ShopAcquisitionMethod @default(PURCHASE)
  purchaseLimit     ShopPurchaseLimit      @default(UNLIMITED)

  title       String
  description String?

  imageUrl String?

  basePrice BigInt

  priceGrowthNumerator   BigInt @default(1)
  priceGrowthDenominator BigInt @default(1)

  effectValue BigInt @default(0)
  itemAmount  BigInt @default(1)

  maxLevel        Int?
  maximumPurchases Int?

  minimumVipLevel    Int @default(0)
  minimumPlayerLevel Int @default(0)

  cosmeticId String? @unique

  unlockActionType   ShopUnlockActionType?
  unlockVerification ShopUnlockVerification?

  unlockInstructions String?
  actionUrl          String?

  telegramChannelUsername String?
  telegramChatId           String?

  targetValue BigInt?

  startsAt DateTime?
  endsAt   DateTime?

  sortOrder Int @default(0)

  isActive   Boolean @default(true)
  isVisible  Boolean @default(true)
  isFeatured Boolean @default(false)

  requirements Json?
  metadata     Json?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playerItems PlayerShopItem[]
  purchases   ShopPurchase[]

  @@index([type, isActive, isVisible])
  @@index([category, isActive, isVisible, sortOrder])
  @@index([effect])
  @@index([acquisitionMethod])
  @@index([minimumVipLevel])
  @@index([minimumPlayerLevel])
  @@index([startsAt, endsAt])
  @@index([isActive, isVisible, deletedAt])
  @@index([sortOrder])
  @@index([createdAt])
}

model PlayerShopItem {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopItemId String
  shopItem   ShopItem @relation(fields: [shopItemId], references: [id], onDelete: Cascade)

  level Int @default(0)

  quantity BigInt @default(0)

  purchaseCount Int @default(0)

  isOwned    Boolean @default(false)
  isEquipped Boolean @default(false)

  purchasedAt DateTime?
  equippedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, shopItemId])
  @@index([userId, isOwned])
  @@index([userId, isEquipped])
  @@index([userId, purchaseCount])
  @@index([shopItemId])
}

model ShopPurchase {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopItemId String
  shopItem   ShopItem @relation(fields: [shopItemId], references: [id], onDelete: Restrict)

  idempotencyKey String @unique

  status ShopPurchaseStatus @default(COMPLETED)

  quantity BigInt @default(1)

  unitPrice  BigInt
  totalPrice BigInt

  balanceBefore BigInt
  balanceAfter  BigInt

  levelBefore Int?
  levelAfter  Int?

  gameStateRevisionBefore Int?
  gameStateRevisionAfter  Int?

  metadata Json?

  createdAt  DateTime  @default(now())
  refundedAt DateTime?

  @@index([userId, createdAt])
  @@index([shopItemId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model BalanceTransaction {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  direction BalanceTransactionDirection
  source    BalanceTransactionSource

  amount        BigInt
  balanceBefore BigInt
  balanceAfter  BigInt

  idempotencyKey String @unique

  referenceType String?
  referenceId   String?

  description String?
  metadata    Json?

  createdBy String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([source, createdAt])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model AdminAuditLog {
  id String @id @default(cuid())

  actor String

  action     String
  entityType String
  entityId   String?

  targetUserId String?
  targetUser   User?   @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  reason String?

  beforeState Json?
  afterState  Json?
  metadata    Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([actor, createdAt])
  @@index([entityType, entityId])
  @@index([targetUserId, createdAt])
  @@index([createdAt])
}